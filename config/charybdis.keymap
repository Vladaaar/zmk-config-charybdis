#include <dt-bindings/zmk/mouse.h>
#include <behaviors/mouse_keys.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    chosen { zmk,physical-layout = &charybdis_6col_layout; };
};

&mt {
    quick-tap-ms = <200>;
    flavor = "tap-preferred";
    tapping-term-ms = <170>;
};

&lt {
    quick-tap-ms = <200>;
    flavor = "tap-preferred";
    tapping-term-ms = <170>;
};


/ {
    macros {
        To1_macro: To1_macro {
            compatible = "zmk,behavior-macro";
            label = "To1_macro";
            #binding-cells = <0>;
            bindings = <&rgb_ug RGB_EFF &rgb_ug RGB_COLOR_HSB(128,100,50) &to 1>;
        };

        To0_macro: To0_macro {
            compatible = "zmk,behavior-macro";
            label = "To0_macro";
            #binding-cells = <0>;
            bindings = <&rgb_ug RGB_EFR &to 0>;
        };

        To2_macro: To2_macro {
            compatible = "zmk,behavior-macro";
            label = "To2_macro";
            #binding-cells = <0>;
            bindings =
                <&to 3>,
                <&macro_wait_time 30>,
                <&rgb_ug RGB_COLOR_HSB(250,100,50)>;
        };

        parentheses: parentheses {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&kp LS(N9) &kp LS(N0) &kp LEFT_ARROW>,
                <&macro_pause_for_release>;

            label = "PARENTHESES";
        };

        sym_on_another_layout: octothorp {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings =
                <&kp LC(SPACE) &macro_param_1to1 &kp MACRO_PLACEHOLDER>,
                <&macro_pause_for_release>,
                <&kp LC(SPACE)>;

            label = "OCTOTHORP";
        };

        momentary_change_layout: change_layout {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&kp LC(SPACE)>,
                <&macro_pause_for_release>,
                <&kp LC(SPACE)>;

            label = "CHANGE_LAYOUT";
        };

        brackets: brackets {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&kp LEFT_BRACKET &kp RIGHT_BRACKET &kp LEFT_ARROW>,
                <&macro_pause_for_release>;

            label = "BRACKETS";
        };

        guillemets: guillemets {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&kp LA(RIGHT_BRACKET) &kp LS(LA(RIGHT_BRACKET)) &kp LEFT_ARROW>,
                <&macro_pause_for_release>;

            label = "GUILLEMETS";
        };

        strikethrough: strikethrough {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(X) &kp TILDE &kp TILDE &kp LG(V) &kp TILDE &kp TILDE>;
            label = "STRIKETHROUGH";
        };

        sp_after: sp_after {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings =
                <&macro_param_1to1 &kp MACRO_PLACEHOLDER &kp SPACE>,
                <&macro_pause_for_release>;

            label = "SP_AFTER";
        };

        surround_sp: surround_sp {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings =
                <&kp SPACE &macro_param_1to1 &kp MACRO_PLACEHOLDER &kp SPACE>,
                <&macro_pause_for_release>;

            label = "SURROUND_SP";
        };

        wait_after: wait_after {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings =
                <&macro_param_1to1 &kp MACRO_PLACEHOLDER>,
                <&macro_pause_for_release>;

            label = "WAIT_AFTER";
        };
    };

    combos {
        compatible = "zmk,combos";

        Toggle_game {
            bindings = <&tog 6>;
            key-positions = <26 15 28>;
        };

        MB1_left {
            bindings = <&mkp MB1>;
            key-positions = <40 39>;
        };

        MB2_left {
            bindings = <&mkp MB2>;
            key-positions = <39 38>;
        };

        MB3_left {
            bindings = <&mkp MB3>;
            key-positions = <40 38>;
        };

        MB1_right {
            bindings = <&mkp MB1>;
            key-positions = <43 44>;
        };

        MB2_right {
            bindings = <&mkp MB2>;
            key-positions = <44 45>;
        };

        MB3_right {
            bindings = <&mkp MB3>;
            key-positions = <43 45>;
        };

        up {
            bindings = <&kp UP>;
            key-positions = <15 20>;
        };

        left {
            bindings = <&kp LEFT>;
            key-positions = <26 31>;
        };

        down {
            bindings = <&kp DOWN>;
            key-positions = <27 32>;
        };

        right {
            bindings = <&kp RIGHT>;
            key-positions = <28 33>;
        };
    };

    behaviors {
        sp_after_on_hold: sp_after_on_hold {
            compatible = "zmk,behavior-hold-tap";
            label = "SP_AFTER_ON_HOLD";
            bindings = <&sp_after>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        another_lang_on_hold: another_lang_on_hold {
            compatible = "zmk,behavior-hold-tap";
            label = "ANOTHER_LANG_ON_HOLD";
            bindings = <&momentary_change_layout>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
            hold-trigger-on-release;
        };

        parentheses_on_hold: parentheses_on_hold {
            compatible = "zmk,behavior-hold-tap";
            label = "PARENTHESES_ON_HOLD";
            bindings = <&parentheses>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        brackets_on_hold: brackets_on_hold {
            compatible = "zmk,behavior-hold-tap";
            label = "BRACKETS_ON_HOLD";
            bindings = <&brackets>, <&kp>;

            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
        };

        guillemets_on_hold: guillemets_on_hold {
            compatible = "zmk,behavior-hold-tap";
            label = "GUILLEMETS_ON_HOLD";
            bindings = <&guillemets>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        lang: lang {
            compatible = "zmk,behavior-tap-dance";
            label = "LANG";
            #binding-cells = <0>;
            bindings = <&another_lang_on_hold 0 LC(SPACE)>, <&kp LA(LCTRL)>;
        };

        shift_dance: shift_dance {
            compatible = "zmk,behavior-tap-dance";
            label = "SHIFT_DANCE";
            #binding-cells = <0>;
            bindings = <&sk LEFT_SHIFT>, <&kp CAPS>;
        };

        dash_on_hold: dash_on_hold {
            compatible = "zmk,behavior-hold-tap";
            label = "DASH_ON_HOLD";
            bindings = <&surround_sp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        punct: punct {
            compatible = "zmk,behavior-tap-dance";
            label = "PUNCT";
            #binding-cells = <0>;
            bindings = <&splayer LCMD LS(SLASH)>, <&sp_after SLASH>;
        };

        splayer: splayer {
            compatible = "zmk,behavior-hold-tap";
            label = "SPLAYER";
            bindings = <&kp>, <&sp_after>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        once_sym_on_hold: once_sym_on_hold {
            compatible = "zmk,behavior-hold-tap";
            label = "ONCE_SYM_ON_HOLD";
            bindings = <&wait_after>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        QWERTY {
            bindings = <
&once_sym_on_hold ESCAPE EQUAL  &mt LS(N1) NUMBER_1        &mt LS(N2) NUMBER_2        &mt LS(NUMBER_3) NUMBER_3  &mt LS(N4) NUMBER_4        &mt LS(N5) NUMBER_5    &mt RS(N6) NUMBER_6  &mt RS(N7) NUMBER_7  &mt RS(N8) NUMBER_8          &parentheses_on_hold 0 N9  &brackets_on_hold 0 NUMBER_0  &dash_on_hold LS(LA(MINUS)) MINUS
&kp RIGHT_BRACKET               &mt LS(LCTRL) Q            &mt LS(LEFT_ALT) W         &mt LS(LCMD) E             &kp R                      &mt GRAVE T            &kp Y                &kp U                &mt RS(RCMD) I               &mt RS(RIGHT_ALT) O        &mt RS(RCTRL) P               &mt RIGHT_BRACKET LEFT_BRACKET
&kp BACKSLASH                   &mt LCTRL A                &mt LEFT_ALT S             &mt LCMD D                 &mt LSHIFT F               &kp G                  &kp H                &mt RSHIFT J         &mt RCMD K                   &mt RIGHT_ALT L            &mt RCTRL SEMI                &lt 5 SQT
&kp LEFT                        &once_sym_on_hold LG(Z) Z  &once_sym_on_hold LG(X) X  &once_sym_on_hold LG(C) C  &once_sym_on_hold LG(V) V  &kp B                  &kp N                &kp M                &guillemets_on_hold 0 COMMA  &lt 4 DOT                  &mt BACKSLASH SLASH           &kp RIGHT
                                                                                      &lang                      &lt 1 SPACE                &sk LEFT_SHIFT         &punct               &kp SPACE
                                                                                                                 &lt 2 TAB                  &mt LCTRL BACKSPACE    &mt LEFT_ALT RET
            >;
        };

        SYMBOLS {
            bindings = <
&once_sym_on_hold LA(E) GRAVE  &trans    &trans  &trans    &kp LA(N8)  &trans         &trans        &trans       &trans        &trans                &trans                 &kp EQUAL
&once_sym_on_hold LA(N) TILDE  &kp EXCL  &kp AT  &kp HASH  &kp DOLLAR  &kp PERCENT    &kp CARET     &kp AMPS     &kp ASTRK     &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp UNDER
&kp LBKT                       &trans    &trans  &trans    &trans      &kp PIPE       &kp QUESTION  &trans       &trans        &trans                &trans                 &kp RBKT
&kp SLASH                      &trans    &trans  &trans    &trans      &kp LT         &kp GT        &kp KP_PLUS  &kp KP_MINUS  &kp KP_MULTIPLY       &kp KP_DIVIDE          &kp BSLH
                                                 &trans    &trans      &trans         &trans        &kp SPACE
                                                           &trans      &trans         &trans
            >;
        };

        NAV_EDIT {
            bindings = <
&trans  &trans     &trans     &trans     &trans     &trans       &trans                           &trans         &trans         &trans       &trans     &trans
&trans  &trans     &trans     &trans     &trans     &trans       &trans                           &kp HOME       &kp PAGE_DOWN  &kp PAGE_UP  &kp END    &trans
&trans  &trans     &trans     &trans     &trans     &trans       &mt LG(LEFT) LA(LEFT_ARROW)      &kp LEFT       &kp DOWN       &kp UP       &kp RIGHT  &mt LG(RIGHT) LA(RIGHT)
&trans  &kp LG(Z)  &kp LG(X)  &kp LG(C)  &kp LG(V)  &kp LG(B)    &mt LG(BACKSPACE) LA(BACKSPACE)  &kp BACKSPACE  &kp INS        &kp LC(T)    &kp DEL    &mt LG(DEL) LA(DEL)
                              &trans     &trans     &trans       &trans                           &trans
                                         &trans     &trans       &trans
            >;
        };

        FUNCTIONS {
            bindings = <
&out OUT_TOG  &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2  &bt BT_SEL 3          &bt BT_SEL 4      &bt BT_PRV  &bt BT_NXT  &trans            &bt BT_CLR  &trans             &trans
&out OUT_BLE  &kp C_BRI_DEC  &kp C_BRI_INC  &trans        &kp LG(LS(NUMBER_4))  &kp LG(LS(N7))    &trans      &kp C_PREV  &kp C_PLAY_PAUSE  &kp C_NEXT  &kp C_VOLUME_DOWN  &kp C_VOL_UP
&out OUT_USB  &trans         &trans         &trans        &trans                &trans            &trans      &trans      &trans            &trans      &trans             &kp K_MUTE
&kp F12       &kp F1         &kp F2         &kp F3        &kp F4                &kp F5            &kp F6      &kp F7      &kp F8            &kp F9      &kp F10            &kp F11
                                            &trans        &trans                &trans            &trans      &trans
                                                          &trans                &trans            &trans
            >;
        };

        scroll-layers {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
                        &trans  &trans  &trans    &trans  &trans
                                &trans  &trans    &trans
            >;
        };

        snipe-layers {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
                        &trans  &trans  &trans    &trans  &trans
                                &trans  &trans    &trans
            >;
        };

        Game {
            bindings = <
&kp ESCAPE      &kp NUMBER_1    &kp N2  &kp N3  &kp N4  &kp N5    &trans  &trans  &trans  &trans  &trans  &trans
&kp TAB         &kp TAB         &kp Q   &kp W   &kp E   &kp R     &trans  &trans  &trans  &trans  &trans  &trans
&none           &none           &kp A   &kp S   &kp D   &kp F     &trans  &trans  &trans  &trans  &trans  &trans
&kp LEFT_SHIFT  &kp LEFT_SHIFT  &kp Z   &kp X   &kp C   &kp V     &trans  &trans  &trans  &trans  &trans  &trans
                                        &trans  &trans  &trans    &trans  &trans
                                                &trans  &trans    &trans
            >;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        function {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };
};
